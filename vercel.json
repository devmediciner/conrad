{
  "rewrites": [
    {
      "source": "/caso/:idOrNum",
      "destination": "/api/preview?type=caso&id=:idOrNum"
    },
    {
      "source": "/artigo/:slug",
      "destination": "/api/preview?type=artigo&id=:slug"
    },
    {
      "source": "/tutorial",
      "destination": "/api/preview?type=tutorial"
    },
    {
      "source": "/tutorial-casos",
      "destination": "/api/preview?type=tutorial"
    },
    {
      "source": "/tutorial-artigos",
      "destination": "/api/preview?type=tutorial"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
